{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "globals": {
    "React": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^(_|React|App|CategorySelector|ProfileCard|ImageWorkflow|existingPrompt)"
    }],
    "no-console": "off",
    "no-empty": ["warn", { "allowEmptyCatch": true }]
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "*.test.js"]
}
